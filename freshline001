<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reggio Calabria Club · complete roster</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        body {
            background: #e8ecf2;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 1.5rem;
            margin: 0;
        }
        .roster-card {
            max-width: 1400px;
            width: 100%;
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 20px 35px -8px rgba(0, 20, 30, 0.25);
            overflow: hidden;
            border: 1px solid #d6dee7;
        }
        .header {
            background: #1e2b3a;
            padding: 1.8rem 2rem 1.4rem 2rem;
            color: white;
        }
        .club-name {
            font-size: 2rem;
            font-weight: 600;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .club-name span {
            background: #c49a2b;
            color: #1e2b3a;
            font-size: 0.9rem;
            font-weight: 600;
            padding: 0.2rem 1rem;
            border-radius: 30px;
            letter-spacing: 0.3px;
        }
        .sub-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1.5rem;
            margin-top: 1.2rem;
        }
        .date-block {
            background: #2a3a4b;
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            font-size: 1rem;
            font-weight: 400;
            color: #e0edf5;
        }
        .date-block input {
            background: white;
            border: none;
            padding: 0.4rem 1rem;
            border-radius: 30px;
            font-size: 0.9rem;
            width: 170px;
            color: #0b1a26;
            font-weight: 500;
        }
        .legend {
            display: flex;
            gap: 1.5rem;
            color: #ccdbe9;
            font-size: 0.85rem;
            flex-wrap: wrap;
        }
        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            table-layout: fixed;
        }
        th {
            background: #f1f5f9;
            color: #1e2b3a;
            font-weight: 600;
            font-size: 0.85rem;
            padding: 0.8rem 0.2rem;
            text-align: center;
            border-bottom: 2px solid #cbd5e1;
            border-right: 1px solid #dde5ed;
        }
        th:last-child { border-right: none; }
        td {
            padding: 0.6rem 0.2rem;
            border-bottom: 1px solid #e6edf4;
            text-align: center;
            vertical-align: middle;
            background: white;
        }
        .room-col {
            background: #f9fcff;
            font-weight: 600;
            color: #14222e;
            text-align: left;
            padding-left: 1rem;
            font-size: 0.95rem;
            border-right: 1px solid #d2dde9;
            width: 140px;
        }
        .room-code {
            display: inline-block;
            background: #dde5f0;
            border-radius: 30px;
            padding: 0.1rem 0.6rem;
            font-size: 0.65rem;
            font-weight: 700;
            margin-left: 6px;
            color: #14222e;
            letter-spacing: 0.3px;
        }
        .day-cell {
            min-width: 100px;
        }
        .signoff {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }
        .signoff input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: #8b1e1e;
            cursor: pointer;
        }
        .signoff input[type="text"] {
            width: 90%;
            max-width: 90px;
            padding: 4px 4px;
            border: 1px solid #b9c9da;
            border-radius: 30px;
            font-size: 0.7rem;
            text-align: center;
            background: #ffffff;
        }
        .signoff input[type="number"] {
            width: 70px;
            padding: 4px;
            border: 1px solid #b9c9da;
            border-radius: 30px;
            font-size: 0.7rem;
            text-align: center;
            background: #ffffff;
            -moz-appearance: textfield;
        }
        .signoff input[type="number"]::-webkit-outer-spin-button,
        .signoff input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        .signoff input:focus {
            border-color: #8b1e1e;
            outline: none;
            box-shadow: 0 0 0 2px rgba(139,30,30,0.15);
        }
        .total-col {
            font-weight: 600;
            background: #f0f5fb;
            color: #1e2b3a;
            width: 70px;
            border-left: 1px solid #d2dde9;
        }
        .footer-bar {
            background: #f0f4fa;
            padding: 1.2rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            border-top: 1px solid #cfddee;
            font-size: 0.9rem;
            color: #2b3f52;
        }
        .print-btn {
            background: #1e2b3a;
            color: white;
            border: none;
            padding: 0.6rem 2rem;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.15s;
            font-size: 0.9rem;
            border: 1px solid #1e2b3a;
        }
        .print-btn:hover {
            background: #8b1e1e;
            border-color: #8b1e1e;
        }
        .footer-note {
            display: flex;
            gap: 1.5rem;
        }
        @media (max-width: 900px) {
            table, thead, tbody, tr, th, td { display: block; }
            thead tr { display: none; }
            tr {
                margin-bottom: 1.5rem;
                border: 1px solid #d7e1ec;
                border-radius: 16px;
                overflow: hidden;
            }
            td {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0.8rem 1.2rem;
                border-bottom: 1px solid #e2eaf3;
                text-align: right;
            }
            .room-col {
                background: #e5ecf5;
                font-weight: 700;
                border-right: none;
                justify-content: flex-start;
                gap: 10px;
                padding-left: 1.2rem;
            }
            td:before {
                content: attr(data-label);
                font-weight: 600;
                color: #1d384c;
                font-size: 0.8rem;
                text-transform: uppercase;
            }
            .total-col {
                border-left: none;
                background: #f0f5fb;
            }
            .signoff {
                width: 100%;
            }
        }
    </style>
</head>
<body>
<div class="roster-card">
    <div class="header">
        <div class="club-name">
            Reggio Calabria Club <span>cleaning & guests</span>
        </div>
        <div class="sub-header">
