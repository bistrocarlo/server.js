                <td class="total-col" data-label="Total guests">0</td>
            </tr>
        </tbody>
    </table>

    <div class="footer-bar">
        <div class="footer-note">
            <span>🧹 Cleaner signs after finishing</span>
            <span>👥 Enter guest numbers for drink planning</span>
        </div>
        <button class="print-btn" onclick="window.print()">🖨️ Print roster</button>
    </div>
</div>

<script>
    (function() {
        // Function to update total for a specific row
        function updateRowTotal(row) {
            const guestInputs = row.querySelectorAll('input.guest-count');
            let total = 0;
            guestInputs.forEach(input => {
                const val = parseInt(input.value, 10);
                if (!isNaN(val)) total += val;
            });
            const totalCell = row.querySelector('.total-col');
            if (totalCell) totalCell.textContent = total;
        }

        // Attach event listeners to all guest-count inputs
        const rows = document.querySelectorAll('tbody tr');
        rows.forEach(row => {
            const guestInputs = row.querySelectorAll('input.guest-count');
            guestInputs.forEach(input => {
                input.addEventListener('input', function() {
                    updateRowTotal(row);
                });
                // Also trigger on blur in case of weird behavior
                input.addEventListener('blur', function() {
                    updateRowTotal(row);
                });
            });
            // Initial update
            updateRowTotal(row);
        });

        // Optional: allow cleaner name fields to be pre-filled? not needed
        // Also handle date input if desired – just a placeholder
    })();
</script>
</body>
</html>