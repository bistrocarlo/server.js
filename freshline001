                </td>
                <td data-label="Wednesday" class="day-cell">
                    <div class="signoff">
                        <input type="checkbox" class="clean-check">
                        <input type="text" placeholder="name" class="cleaner-name">
                        <input type="number" min="0" value="0" class="guest-count" step="1">
                    </div>
                </td>
                <td data-label="Thursday" class="day-cell">
                    <div class="signoff">
                        <input type="checkbox" class="clean-check">
                        <input type="text" placeholder="name" class="cleaner-name">
                        <input type="number" min="0" value="0" class="guest-count" step="1">
                    </div>
                </td>
                <td data-label="Friday" class="day-cell">
                    <div class="signoff">
                        <input type="checkbox" class="clean-check">
                        <input type="text" placeholder="name" class="cleaner-name">
                        <input type="number" min="0" value="0" class="guest-count" step="1">
                    </div>
                </td>
                <td data-label="Saturday" class="day-cell">
                    <div class="signoff">
                        <input type="checkbox" class="clean-check">
                        <input type="text" placeholder="name" class="cleaner-name">
                        <input type="number" min="0" value="0" class="guest-count" step="1">
                    </div>
                </td>
                <td data-label="Sunday" class="day-cell">
                    <div class="signoff">
                        <input type="checkbox" class="clean-check">
                        <input type="text" placeholder="name" class="cleaner-name">
                        <input type="number" min="0" value="0" class="guest-count" step="1">
                    </div>
                </td>
                <td data-label="Monday" class="day-cell">
                    <div class="signoff">
                        <input type="checkbox" class="clean-check">
                        <input type="text" placeholder="name" class="cleaner-name">
                        <input type="number" min="0" value="0" class="guest-count" step="1">
                    </div>
                </td>
                <td class="total-col" data-label="Total guests">0</td>
            </tr>
            <!-- Bistroteca -->
            <tr id="row-BT">
                <td class="room-col" data-label="Room">Bistroteca <span class="room-code">BT</span></td>
                <td data-label="Tuesday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Wednesday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Thursday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Friday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Saturday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Sunday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Monday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td class="total-col" data-label="Total guests">0</td>
            </tr>
            <!-- Ottimo Room -->
            <tr id="row-OR">
                <td class="room-col" data-label="Room">Ottimo Room <span class="room-code">OR</span></td>
                <td data-label="Tuesday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Wednesday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Thursday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Friday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Saturday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Sunday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Monday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td class="total-col" data-label="Total guests">0</td>
            </tr>
            <!-- Sala Reggio Ballroom -->
            <tr id="row-SR">
                <td class="room-col" data-label="Room">Sala Reggio Ballroom <span class="room-code">SR</span></td>
                <td data-label="Tuesday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Wednesday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Thursday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
                <td data-label="Friday" class="day-cell"><div class="signoff"><input type="checkbox" class="clean-check"><input type="text" placeholder="name" class="cleaner-name"><input type="number" min="0" value="0" class="guest-count" step="1"></div></td>
