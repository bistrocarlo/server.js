        </thead>
        <tbody>
            <!-- Members Lounge -->
            <tr id="row-ML">
                <td class="room-col" data-label="Room">Members Lounge <span class="room-code">ML</span></td>
                <td data-label="Tuesday" class="day-cell">
                    <div class="signoff">
                        <input type="checkbox" class="clean-check">
                        <input type="text" placeholder="name" class="cleaner-name">
                        <input type="number" min="0" value="0" class="guest-count" step="1">
